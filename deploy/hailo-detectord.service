[Unit]
Description=Remote Hailo detector worker for Frigate
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hailo-detectord
Group=hailo-detectord
WorkingDirectory=/opt/hailo-detectord/app
EnvironmentFile=/etc/hailo-detectord.env
ExecStart=/opt/hailo-detectord/venv/bin/hailo-detectord --host 0.0.0.0 --port 32168
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
